---
const domainName = "doctorbambu-com-app";
---
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{domainName} | Doctor Bambu Ecosystem</title>
		<style>
			body { background: #0a0f0a; color: #d1ffd1; font-family: sans-serif; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; }
			.card { border: 1px solid #1b4d1b; padding: 2rem; border-radius: 1rem; text-align: center; box-shadow: 0 0 20px rgba(0,255,0,0.1); }
			h1 { color: #4ade80; }
		</style>
	</head>
	<body>
		<div class="card">
			<h1>{domainName}</h1>
			<p>Status: Biophotonic Foundation Initialized</p>
			<p><i>The Bambu Groove is active.</i></p>
		</div>
	</body>
</html>
